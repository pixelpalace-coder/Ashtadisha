rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Packages: Everyone can read (to see the site), only Admin can write
    match /packages/{packageId} {
      allow read: if true;
      allow write: if false; 
    }
    
    // 2. Users: Only the authenticated owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 3. Bookings:
    // - Authenticated users can create and read their own bookings
    // - Prevention of modifying confirmed bookings from the client
    match /bookings/{bookingId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow update, delete: if false; 
    }
    
    // 4. Enquiries (AI Planner / Contact):
    // - Anyone (including guests) can submit an enquiry
    // - Only Admin (via Firebase Console) can read these enquiries
    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read: if false;
    }
  }
}
