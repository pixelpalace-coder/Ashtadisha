rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Receipt Storage: Allow authenticated users to upload their own receipts
    match /receipts/{bookingId} {
      allow write: if request.auth != null;
      allow read: if true; // Standard display via download token
    }
    
    // Default Deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
